    "express": "^5.1.0",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.1",
    "prisma": "^6.19.3",

{
  "compilerOptions": {
    "target": "ES2020",

    "module": "NodeNext",

    "moduleResolution": "NodeNext",

    "rootDir": "./src",

    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "resolveJsonModule": true,

    "verbatimModuleSyntax": false,

    "baseUrl": "./src",

    "paths": {
      "@config/*": ["config/*"],
      "@ws/*": ["ws/*"],
      "@modules/*": ["modules/*"],
      "@database/*": ["database/*"],
      "@shared/*": ["shared/*"]
    },

    "ignoreDeprecations": "6.0"
  },

  "include": ["src"],

  "exclude": ["node_modules", "dist"]
}
